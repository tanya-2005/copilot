# Copy this file to .env and fill in real values. Never commit .env itself.

# Supabase connection string. Find it in your Supabase project:
# Project Settings -> Database -> Connection string -> URI (use the "Session pooler" one for scripts/Actions)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres

# OpenRouter API key (free tier — no card required) from openrouter.ai/keys
OPENROUTER_API_KEY=...

# Optional: override the default model. Defaults to "openrouter/free", which
# routes each request across OpenRouter's pool of free models instead of one
# fixed model (see README "AI provider" section). Pick a specific free model
# slug from openrouter.ai/models (filter by price = free) if you want
# consistent behavior instead, e.g. meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=openrouter/free

# Tavily API key (free tier — 1,000 searches/month, no card required) from
# tavily.com. Used only for web-search-grounded features: broader-web job
# discovery (config/sources.yaml web_discovery.enabled) and the recruiter
# contact finder. Required if web_discovery stays enabled (it is by default).
TAVILY_API_KEY=...

# Email digest (optional, needed for notifications module later)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
DIGEST_TO=you@gmail.com

# Comma-separated origins allowed to call the FastAPI backend (backend/main.py).
# Defaults to the Vite dev server if unset.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
